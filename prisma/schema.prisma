
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider  = "postgresql"
}

model Users {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   @db.VarChar(255)
  role      String   @default("USER")
  createdAt DateTime @default(now())
}

model Books {
  id        Int      @id @default(autoincrement())
  title     String
  author    String
  year      Int
  available Boolean  @default(true)
  createdAt DateTime @default(now())
}